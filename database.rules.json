{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "messages": {
      "$receiverUID": {
        ".indexOn": ["timestamp", "delivered"],
        "$messageId": {}
      }
    },
    "sentMessages": {
      "$senderUID": {
        "$receiverUID": {
          ".indexOn": ["timestamp", "delivered"],
          "$messageId": {}
        }
      }
    }
  }
}

