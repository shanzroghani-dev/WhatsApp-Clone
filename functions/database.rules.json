{
  "rules": {
    ".read": "auth != null",
    ".write": "auth != null",
    "messages": {
      ".indexOn": ["fromId", "toId", "timestamp", "delivered", "read"],
      "$messageId": {
        ".read": "auth != null && (data.child('fromId').val() === auth.uid || data.child('toId').val() === auth.uid)",
        ".write": "auth != null"
      }
    }
  }
}